{
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run cloud:build",
  "outputDirectory": "dist",
  "nodeVersion": "20.18.0",
  "headers": [
    {
      "source": "/data/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    },
    {
      "source": "/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600"
        }
      ]
    }
  ]
}
